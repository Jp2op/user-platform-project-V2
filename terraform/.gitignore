# terraform/.gitignore

# Local state — never commit, use remote S3 backend
*.tfstate
*.tfstate.backup
.terraform/
.terraform.lock.hcl    # commit this one actually — it locks provider versions

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Plan files — contain sensitive output, never commit
*.tfplan
tfplan

# Secrets — should never exist as files but just in case
*.pem
*.key
secrets.tfvars
secret.tfvars